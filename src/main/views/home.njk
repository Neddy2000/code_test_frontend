{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% extends "template.njk" %}

{% block content %}
  <h1 class="govuk-heading-xl">Task Dashboard</h1>
  
  {{ govukButton({
    text: "Create a new Task",
    href: "/tasks/new",
    isStartButton: true
  }) }}

  {% set tableRows = [] %}
  
  {% for task in tasks %}
    
    {% set statusClass = "govuk-tag--blue" if task.status == "IN_PROGRESS" else ("govuk-tag--green" if task.status == "DONE" else "govuk-tag--grey") %}
    {% set priorityClass = "govuk-tag--red" if task.priority == "CRITICAL" else ("govuk-tag--orange" if task.priority == "HIGH" else ("govuk-tag--yellow" if task.priority == "MEDIUM" else "govuk-tag--blue")) %}
    
    {% set statusHtml %}
      {{ govukTag({ text: task.status, classes: statusClass }) }}
    {% endset %}

    {% set priorityHtml %}
      {{ govukTag({ text: task.priority, classes: priorityClass }) }}
    {% endset %}

    {% set actionsHtml %}
      <a href="/tasks/{{ task.id }}" class="govuk-link" style="margin-right: 10px;">View</a>
      <a href="/tasks/{{ task.id }}/edit" class="govuk-link" style="margin-right: 10px;">Edit</a>
      <a href="/tasks/{{ task.id }}/delete" class="govuk-link govuk-!-static-padding-top-2" style="color: #d4351c;">Delete</a>
    {% endset %}

    {% set row = [
      { text: task.title | truncate(30) },
      { text: task.assignedTo.name if task.assignedTo else "Unassigned" },
      { html: priorityHtml },
      { html: statusHtml },
      { text: (task.dueDate | date) or "None" },
      { html: actionsHtml }
    ] %}
    
    {% set tableRows = (tableRows.push(row), tableRows) %}
  {% else %}
    {% set tableRows = [
      [{ text: "No tasks found.", colspan: 6 }]
    ] %}
  {% endfor %}

  {{ govukTable({
    caption: "Current Active Tasks",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: false,
    head: [
      { text: "Title", classes: "govuk-!-width-one-quarter" },
      { text: "Assigned To" },
      { text: "Priority" },
      { text: "Status" },
      { text: "Due Date" },
      { text: "Actions" }
    ],
    rows: tableRows
  }) }}

  {% if tasks.length > 0 %}
    {% from "govuk/components/pagination/macro.njk" import govukPagination %}
    
    {% set paginationItems = [] %}
    {% set totalPagesToShow = totalPages if totalPages > 0 else 1 %}
    {% for i in range(0, totalPagesToShow) %}
      {% set paginationItems = (paginationItems.push({
        number: i + 1,
        href: "/?page=" + i,
        current: i == currentPage
      }), paginationItems) %}
    {% endfor %}

    {{ govukPagination({
      items: paginationItems
    }) }}
  {% endif %}

{% endblock %}
